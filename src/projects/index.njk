---
title: Projects
layout: base.njk
tags: []
eleventyExcludeFromCollections: true
---

<section class="section">
  <div class="container">
    <h1 class="title">Projects</h1>
    <hr />
    {% set projects = collections.projects | reverse %} {% if projects.length >
    0 %}
    <div class="grid is-col-min-9">
      {% for project in projects %}
      <div class="cell">
        <a href="{{ project.url }}" class="has-text-dark">
          <div class="card h-100">
            <div class="card-image">
              <figure class="image is-16by9">
                <img
                  src="{{ project.data.images[0].src }}"
                  alt="{{ project.data.images[0].alt }}"
                  style="object-fit: cover"
                />
              </figure>
            </div>
            <div class="card-content">
              <p class="title is-5">{{ project.data.title }}</p>
              {% if project.data.description %}
              <p class="subtitle is-6 has-text-grey">
                {{ project.data.description }}
              </p>
              {% endif %}
            </div>
          </div>
        </a>
      </div>
      {% endfor %} {% else %}
      <div class="cell">No projects yet.</div>
      {% endif %}
    </div>
  </div>
</section>
