---
layout: base.njk
---

<section class="section">
  <div class="container">
    <div class="columns is-centered">
      <div class="column is-8">
        <article>
          <p class="has-text-grey is-size-7 mb-2">
            {{ page.date | date("MMMM d, yyyy") }}
          </p>
          <h1 class="title">{{ title }}</h1>
          {% if description %}
          <p class="subtitle">{{ description }}</p>
          {% endif %}
          <hr />
          <div class="content">{{ content | safe }}</div>
          {% if topics | length > 0 %}
          <div class="box">
            {% for topic in topics %}
            <span class="tag is-medium">{{ topic }}</span>
            {% endfor %}
          </div>
          {% endif %}
          <hr />
          <a href="/posts/" class="button is-light">&larr; Back to Posts</a>
        </article>
      </div>

      <div class="column is-4">
        <aside>
          {% if links | length > 0 %}
          <div class="box">
            <h2 class="title is-5">Links</h2>
            <ul class="links">
              {% for link in links %}
              <li class="my-1">
                <a
                  href="{{ link.url }}"
                  target="_blank"
                  rel="noopener noreferrer"
                  >{{ link.name }}</a
                >
              </li>
              {% endfor %}
            </ul>
          </div>
          {% endif %}
        </aside>
      </div>
    </div>
  </div>
</section>
