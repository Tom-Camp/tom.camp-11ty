---
layout: base.njk
---

<section class="section">
  <div class="container">
    <div class="columns is-centered">
      <div class="column is-8">
        <article>
          <p class="has-text-grey is-size-7 mb-2">
            {{ page.date | date("MMMM d, yyyy") }}
          </p>
          <h1 class="title">{{ title }}</h1>
          {% if description %}
          <p class="subtitle">{{ description }}</p>
          {% endif %}
          <hr />
          <div class="content">{{ content | safe }}</div>
          {% if topics | length > 0 %}
          <div class="box">
            {% for topic in topics %}
            <span class="tag is-medium">{{ topic }}</span>
            {% endfor %}
          </div>
          {% endif %}
          <hr />
          <a href="/posts/" class="button is-light">&larr; Back to Posts</a>
        </article>
      </div>

      <div class="column is-4 mt-6">
        <aside>
          {% if repo %}
          <a href="{{ repo }}" target="_blank" rel="noopener noreferrer">
            <div class="card p-3 mb-4 is-clickable has-text-centered">
              <span class="icon mr-2"
                ><img src="/img/github.svg" alt="GitHub Logo"
              /></span>
              <span class="is-size-4 has-text-weight-bold has-text-black-bis"
                >Code Repository</span
              >
            </div>
          </a>
          {% endif %} {% if hardware | length > 0 %}
          <div class="box">
            <h2 class="title is-5">
              <span class="icon mr-2">
                <img src="/img/hardware.svg" alt="Hardware Logo" />
              </span>
              Hardware
            </h2>
            <ul class="links">
              {% for ware in hardware %}
              <li class="my-1">
                <a
                  href="{{ ware.url }}"
                  target="_blank"
                  rel="noopener noreferrer"
                  >{{ ware.name }}</a
                >
              </li>
              {% endfor %}
            </ul>
          </div>
          {% endif %}
        </aside>
      </div>
    </div>
  </div>
</section>
