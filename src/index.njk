---
title: Home
layout: base.njk
---

<section class="section">
  <div class="container">
    <div class="card is-centered is-family-monospace">
      <div class="card-content has-text-centered">
        <div class="is-italic is-size-4 mb-4">
          “The most disastrous thing that you can ever learn is your first
          programming language.”
        </div>
        <div class="is-size-5">Alan Kay</div>
        <div class="is-size-6">Learning Research Group | Xerox PARC</div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="columns is-centered">
      <div class="column is-8">
        <h2 class="title is-3">Recent Posts</h2>
        {% set recentPosts = collections.posts | reverse | limit(3) %} {% for
        post in recentPosts %}
        <div class="box mb-4">
          <p class="has-text-grey is-size-7 mb-1">
            {{ post.date | date("MMMM d, yyyy") }}
          </p>
          <a href="{{ post.url }}" class="title is-5 has-text-dark"
            >{{ post.data.title }}</a
          >
          {% if post.data.description %}
          <p class="mt-2">{{ post.data.description }}</p>
          {% endif %}
        </div>
        {% else %}
        <p>No posts yet.</p>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
