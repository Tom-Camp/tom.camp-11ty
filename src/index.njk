---
title: Home
layout: base.njk
---

<section class="hero is-primary is-medium">
  <div class="hero-body">
    <div class="container">
      <p class="title">Welcome to tom.camp</p>
      <p class="subtitle">A personal site built with 11ty and Bulma</p>
      <a href="/posts/" class="button is-light is-medium">Read the Posts</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="columns is-centered">
      <div class="column is-8">
        <h2 class="title is-3">Recent Posts</h2>
        {% set recentPosts = collections.posts | reverse | limit(3) %} {% for
        post in recentPosts %}
        <div class="box mb-4">
          <p class="has-text-grey is-size-7 mb-1">
            {{ post.date | date("MMMM d, yyyy") }}
          </p>
          <a href="{{ post.url }}" class="title is-5 has-text-dark"
            >{{ post.data.title }}</a
          >
          {% if post.data.description %}
          <p class="mt-2">{{ post.data.description }}</p>
          {% endif %}
        </div>
        {% else %}
        <p>No posts yet.</p>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
